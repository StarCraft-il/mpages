(function () {
    var STR = window.STR || {};

    STR.padStringZero = function (str, len, c) {
        var s = str,
          c = c || "0";
        while (s.length < len) s = c + s;
        return s;
    };

    window.STR = STR;
})();

String.prototype.padZero = function (len, c) {
    var s = this,
      c = c || "0";
    while (s.length < len) s = c + s;
    return s;
};

function AllowUnsignedIntegerOnlyNoCtrl() {
    // Only for mtvIDField
    if (event.keyCode < 48 || event.keyCode > 57) {
        if (event.keyCode == 13) {
            var ctrl = event.target || event.srcElement;
            ctrl.onblur();
            event.returnValue = true;
        } else {
            event.returnValue = false;
        }
    } else {
        var ctrl = event.target || event.srcElement;
        if (parseInt(ctrl.value) == 0) {
            ctrl.value = "";
            event.returnValue = false;
        }
    }
}

function calcIdCheck(strId) {
    var sum = 0;
    var temp, decade, checkDigit;
    var j = 0;
    var strId_length = strId.length;
    for (var i = strId_length; i >= 1; i--) {
        j++;
        if (j % 2 != 0) {
            temp = parseInt(strId.substring(i - 1, i), "10") * 2;
            if (temp > 8) sum += 1 + (temp % 10);
            else sum += temp;
        } else {
            sum += parseInt(strId.substring(i - 1, i), "10");
        }
    }

    if (sum % 10 != 0) decade = (parseInt(sum / 10) + 1) * 10;
    else decade = sum;
    checkDigit = decade - sum;

    return checkDigit;

